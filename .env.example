# Server
PORT=4000
CORS_ORIGIN=http://localhost:3000

# Database (same DB as Payload app for migration)
DATABASE_URL=mongodb://127.0.0.1/superfreak

# Redis (cache + order-messages pub/sub)
REDIS_URL=redis://localhost:6379

# Auth (B2)
JWT_SECRET=your-jwt-secret-min-32-chars

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL of this API (for Google callback URL). e.g. https://api.yourdomain.com
PUBLIC_API_URL=http://localhost:4000
# Frontend URL to redirect to after Google sign-in
FRONTEND_URL=http://localhost:3000

# R2 / S3 (B5, B11, B12)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# Public URL for R2 (e.g. https://pub-xxx.r2.dev or custom domain). Enable "Public access" on the bucket.
R2_PUBLIC_URL=

# Midtrans (B10)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# Resend (optional, emails)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=

# Shipping (B14)
BITESHIP_API_KEY=
RAJAONGKIR_SHIPPING_COST_API=
RAJAONGKIR_SHIPPING_DELIVERY_API=

# Blog (B12, admin)
BLOG_API_KEY=

# Slice (B15 – SuperSlice proxy)
SUPERSLICE_API_URL=http://localhost:8000
