# =========================
# Core app (required)
# =========================
NODE_ENV=development
PORT=4000
CORS_ORIGIN=http://localhost:3000
DATABASE_URL=mongodb://127.0.0.1/superfreak
REDIS_URL=redis://localhost:6379
FRONTEND_URL=http://localhost:3000

# Docker security defaults (used by docker-compose.yml)
MONGO_INITDB_ROOT_USERNAME=superfreak_admin
MONGO_INITDB_ROOT_PASSWORD=replace-with-strong-mongo-password
REDIS_PASSWORD=replace-with-strong-redis-password

# =========================
# Optional: Google OAuth
# =========================
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Public URL of this API, used for OAuth callback URL
PUBLIC_API_URL=http://localhost:4000

# =========================
# Optional: Cloudflare R2 storage
# =========================
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
# e.g. https://pub-xxx.r2.dev or custom domain
R2_PUBLIC_URL=

# =========================
# Optional: Midtrans payments
# =========================
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false

# =========================
# Optional: Shipping providers
# =========================
BITESHIP_API_KEY=
BITESHIP_ORIGIN_POSTAL_CODE=12440
RAJAONGKIR_SHIPPING_COST_API=

# =========================
# Optional: Blog create endpoint protection
# =========================
BLOG_API_KEY=

# =========================
# Optional: SuperSlice integration
# =========================
SUPERSLICE_API_URL=http://localhost:8000
